# Copy this file to `.env` for local prod-simulation, or set these as project
# variables in Coolify. The dev compose (`docker compose up`) does NOT need any
# of these — it has its own hardcoded dev defaults.

# ───── Postgres ─────
POSTGRES_USER=palvi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=palvi

# ───── Backend ─────
# Generate with: openssl rand -base64 48
JWT_SECRET=changeme-generate-with-openssl-rand-base64-48

# Comma-separated list of allowed frontend origins (no trailing slashes).
# Each value is matched literally against the browser's Origin header.
CORS_ORIGINS=https://palvi.example.cl

# Optional: number of uvicorn workers. Default 2.
# Note: lifespan seeding is not concurrency-safe — on the FIRST deploy with an
# empty DB, two workers can race the "is empty?" check. If the first deploy
# fails with a UNIQUE violation, set this to 1, redeploy, then raise to 2.
# API_WORKERS=2

# Optional: set to "true" to wipe the DB and re-import insumos/metrics.json on
# next API restart. Leave unset for normal idempotent boots.
# FORCE_RESEED=true

# ───── Frontend ─────
# Public URL of the API. Vite resolves this at BUILD time (not runtime), so
# changing it requires rebuilding the web image. Use the full origin without
# trailing slash; the client appends `/api/...` itself.
VITE_API_URL=https://api.palvi.example.cl
